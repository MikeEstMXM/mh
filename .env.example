# Public values can be exposed in browser code if prefixed with NEXT_PUBLIC_.
# Keep secrets server-side only and never rename them to NEXT_PUBLIC_*.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=

# Example server-only API integration placeholders.
EXAMPLE_API_BASE_URL=
EXAMPLE_API_KEY=

# Notion integration for recipe imports.
NOTION_API_KEY=
NOTION_RECIPES_DATABASE_ID=
